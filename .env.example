# ==================== Telegram Bot 配置 ====================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=123456789

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./data/wallet_bot.db

# ==================== 区块链 API 配置（免费） ====================
# Etherscan - https://etherscan.io/apis (免费注册)
ETHERSCAN_API_KEY=your_etherscan_api_key

# BscScan - https://bscscan.com/apis (免费注册)
BSCSCAN_API_KEY=your_bscscan_api_key

# Polygonscan - https://polygonscan.com/apis (免费注册)
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ==================== 会员配置 ====================
# 免费用户每日查询次数
FREE_DAILY_LIMIT=3

# 会员价格
PRICE_MONTHLY=19.9
PRICE_YEARLY=199
PRICE_PRO=99

# ==================== 其他配置 ====================
TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO

# USDT 收款地址（可选，用于自动确认支付）
USDT_TRC20_ADDRESS=your_usdt_trc20_address
